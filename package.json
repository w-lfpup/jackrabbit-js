{
	"name": "@w-lfpup/jackrabbit",
	"description": "A test runner without dependencies",
	"version": "0.2.0",
	"license": "BSD-3-Clause",
	"workspaces": [
		"core",
		"tests",
		"nodejs",
		"webdriver"
	],
	"bin": {
		"jackrabbit": "nodejs/dist/mod.js",
		"jackrabbit_browser": "webdriver/dist/mod.js"
	},
	"scripts": {
		"prepare": "npm run build",
		"build": "npm run --workspaces build",
		"format": "npx prettier --write ./",
		"test": "npx jackrabbit ./tests/dist/mod.js",
		"test:browser": "npx jackrabbit_browser"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/w-lfpup/jackrabbit-js.git"
	},
	"devDependencies": {
		"@types/node": "^22.5.5",
		"prettier": "^3.3.1",
		"typescript": "^5.4.5"
	}
}
