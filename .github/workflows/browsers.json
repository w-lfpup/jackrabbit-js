{
	"host_and_port": "http://127.0.0.1:4000",
	"runAsynchronusly": false,
	"webdrivers": [
		{
			"command": "$GECKOWEBDRIVER/geckodriver -p 4001",
			"title": "Firefox",
			"timeout_ms": 20000,
			"url": "http://127.0.0.1:4001",
			"capabilities": {
				"alwaysMatch": {
					"moz:firefoxOptions": {
						"args": ["-headless"]
					}
				}
			}
		},
		{
			"command": "$CHROMEWEBDRIVER/chromedriver --port=4001",
			"title": "Chrome",
			"timeout_ms": 20000,
			"url": "http://localhost:4001",
			"capabilities": {
				"alwaysMatch": {
					"goog:chromeOptions": {
						"args": ["headless", "disable-gpu", "no-sandbox", "start-maximized", "disable-dev-shm-usage"]
					}
				}
			}
		}
	]
}
