{
	"host_and_port": "http://127.0.0.1:4000",
	"webdrivers": [
		{
			"command": "$CHROMEWEBDRIVER/chromedriver --port=4001",
			"title": "Chrome",
			"timeout_ms": 20000,
			"url": "http://127.0.0.1:4001",
			"capabilities": {
				"desiredCapabilities": {
					"browserName": "chrome",
					"goog:chromeOptions": {
						"args": ["--headless"]
					}
				}
			}
		}
	]
}
