{
	"host_and_port": "http://127.0.0.1:4000",
	"runAsynchronusly": false,
	"webdrivers": [
		{
			"command": "$GECKOWEBDRIVER/geckodriver -p 4005",
			"title": "Firefox",
			"timeout_ms": 20000,
			"url": "http://localhost:4005",
			"capabilities": {
				"alwaysMatch": {
					"moz:firefoxOptions": {
						"args": ["-headless"]
					}
				}
			}
		},
		{
			"title": "Edge",
			"command": "$EDGEWEBDRIVER/msedgedriver --port=4010",
			"timeout_ms": 20000,
			"url": "http://localhost:4010",
			"capabilities": {
				"alwaysMatch": {
					"ms:edgeOptions": {
						"args": [
							"--headless",
							"--disable-gpu",
							"--no-sandbox",
							"--disable-dev-shm-usage"
						]
					}
				}
			}
		}
	]
}
