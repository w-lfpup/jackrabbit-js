{
	"host_and_port": "http://127.0.0.1:4000",
	"runAsynchronusly": false,
	"webdrivers": [
		{
			"command": "$CHROMEWEBDRIVER/chromedriver --port=4001",
			"title": "Chrome",
			"timeout_ms": 20000,
			"url": "http://localhost:4001",
			"capabilities": {
				"alwaysMatch": {
					"goog:chromeOptions": {
						"args": ["--headless", "--disbale-gpu", "--no-sandbox", "--disable-dev-shm-usage"]
					}
				}
			}
		},
		{
			"command": "$EDGEWEBDRIVER/msedgedriver --port=4002",
			"title": "EDGE",
			"timeout_ms": 20000,
			"url": "http://localhost:4002",
			"capabilities": {
				"alwaysMatch": {
					"ms:edgeOptions": {
						"args": ["--headless", "--disbale-gpu", "--no-sandbox", "--disable-dev-shm-usage"]
					}
				}
			}
		}
	]
}
