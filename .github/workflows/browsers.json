{
	"host_and_port": "http://127.0.0.1:4000",
	"webdrivers": [
		{
			"command": "$CHROMEWEBDRIVER/chromedriver --help",
			"title": "Chrome",
			"timeout_ms": 20000,
			"url": "http://127.0.0.1:4001",
			"capabilities": {
				"alwaysMatch": {
					"goog:chromeOptions": {
						"args": ["--headless"]
					}
				}
			}
		},
		{
			"command": "$GECKOWEBDRIVER/geckodriver -p 4001",
			"title": "Firefox",
			"timeout_ms": 20000,
			"url": "http://127.0.0.1:4001",
			"capabilities": {
				"alwaysMatch": {
					"moz:firefoxOptions": {
						"args": ["-headless"]
					}
				}
			}
		}
	]
}
