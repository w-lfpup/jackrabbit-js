{
	"host_and_port": "http://127.0.0.1:4000",
	"runAsynchronusly": false,
	"webdrivers": [
		{
			"command": "$GECKOWEBDRIVER/geckodriver -p 4001",
			"title": "Firefox",
			"timeout_ms": 20000,
			"url": "http://localhost:4001",
			"capabilities": {
				"alwaysMatch": {
					"moz:firefoxOptions": {
						"args": ["-headless"]
					}
				}
			}
		},
		{
			"command": "$EDGEWEBDRIVER/msedgedriver --port=4002",
			"title": "Edge",
			"timeout_ms": 20000,
			"url": "http://localhost:4002",
			"capabilities": {
				"alwaysMatch": {
					"ms:edgeOptions": {
						"args": ["--headless", "--disable-gpu"]
					}
				}
			}
		},
		{
			"command": "$CHROMEWEBDRIVER/chromedriver --port=4003",
			"title": "Chrome",
			"timeout_ms": 20000,
			"url": "http://localhost:4003",
			"capabilities": {
				"alwaysMatch": {
					"goog:chromeOptions": {
						"args": ["--headless"]
					}
				}
			}
		}
	]
}
