{
	"host_and_port": "http://127.0.0.1:4000",
	"runAsynchronusly": false,
	"webdrivers": [
		{
			"command": "$EDGEWEBDRIVER/msedgedriver --port=4003",
			"title": "Edge",
			"timeout_ms": 20000,
			"url": "http://localhost:4003",
			"capabilities": {
				"alwaysMatch": {
					"ms:edgeOptions": {
						"args": [
							"--headless"
						]
					}
				}
			}
		},
		{
			"command": "$CHROMEWEBDRIVER/chromedriver --port=4001",
			"title": "Chrome",
			"timeout_ms": 20000,
			"url": "http://localhost:4001",
			"capabilities": {
				"alwaysMatch": {
					"goog:chromeOptions": {
						"args": [
							"--headless"
						]
					}
				}
			}
		},
		{
			"command": "$GECKOWEBDRIVER/geckodriver -p 4001",
			"title": "Firefox",
			"timeout_ms": 20000,
			"url": "http://127.0.0.1:4001",
			"capabilities": {
				"alwaysMatch": {
					"moz:firefoxOptions": {
						"args": ["-headless"]
					}
				}
			}
		}

	]
}
